$assert LMUL in [1, 2, 4, 8]
$assert(DATATYPE in ["f32", "f16", "u8", "s8"])
#include <assert.h>
#include "src/xnnpack/maxpool.h"
#include <riscv_vector.h>

$CTYPE = {"f32": "float", "f16": "xnn_float16", "u8": "uint8_t", "s8": "int8_t"}[DATATYPE]
$VTYPE = {"f32": "vfloat32m${LMUL}_t", "f16": "vfloat16m${LMUL}_t", "u8": "vuint8m${LMUL}_t", "s8": "vint8${LMUL}_t"}[DATATYPE]
$VLOAD = {"f32: "__riscv_vle32_v_f32m${LMUL}", "f16": "__riscv_vle16_v_f16m${LMUL}", "u8": "__riscv_vle8_v_u8m${LMUL}", "s8": "__riscv_vle8_v_i8m${LMUL}"}[DATATYPE]
$VSTORE = {"f32: "__riscv_vse32_v_f32m${LMUL}", "f16": "__riscv_vse16_v_f16m${LMUL}", "u8": "__riscv_vse8_v_u8m${LMUL}", "s8": "__riscv_vse8_v_i8m${LMUL}"}[DATATYPE]

void xnn_${DATATYPE}_maxpool_minmax_ukernel_9p__rvv_u${LMUL}v(
    size_t output_pixels,
    size_t kernel_elements,
    size_t channels,
    const ${CTYPE}** input,
    size_t input_offset,
    size_t input_pixel_stride,
    ${CTYPE}* output,
    size_t input_increment,
    size_t output_increment,
    const struct xnn_${DATATYPE}_minmax_params* restrict params)
{
  assert(output_pixels != 0);
  assert(kernel_elements != 0);
  assert(channels != 0);

  const ${CTYPE} output_min = params->scalar.min;
  const ${CTYPE} output_max = params->scalar.max;
  do {
    const ${CTYPE}** i = input;

    // First pass: load the inputs, store the max pool in the output.
    const ${CTYPE}* i0 = *i++;
    $for K in range(1, 9):
      const ${CTYPE}* i${K} = ${K} < kernel_elements ? *i++ : i0;
    $for K in range(9):
      i${K} = (const ${CTYPE}*) ((uintptr_t) i${K} + input_offset);

    ${CTYPE}* o = output;
    size_t c = channels;
    do {
      size_t vl = __riscv_vsetvl_e32m${LMUL}(c);
      $for K in range(9):
        ${VTYPE} vi${K} = $VLOAD(i${K}, vl); i${K} += vl;

        ${VTYPE} vmax01 = __riscv_vfmax(vi0, vi1, vl);
        ${VTYPE} vmax23 = __riscv_vfmax(vi2, vi3, vl);
        ${VTYPE} vmax45 = __riscv_vfmax(vi4, vi5, vl);
        ${VTYPE} vmax67 = __riscv_vfmax(vi6, vi7, vl);
        ${VTYPE} vmax018 = __riscv_vfmax(vmax01, vi8, vl);

        ${VTYPE} vmax2345 = __riscv_vfmax(vmax23, vmax45, vl);
        ${VTYPE} vmax01678 = __riscv_vfmax(vmax67, vmax018, vl);
        ${VTYPE} vacc = __riscv_vfmax(vmax2345, vmax01678, vl);

        vacc = __riscv_vfmax(vacc, output_min, vl);
        vacc = __riscv_vfmin(vacc, output_max, vl);
        ${VSTORE}(o, vacc, vl); o += vl;

      c -= vl;
    } while (c != 0);

    // Passes 1 - n: Max more inputs to the output.
    for (ptrdiff_t k = (ptrdiff_t) kernel_elements - 9; k > 0; k -= 8) {

      const ${CTYPE}* i0 = *i++;
      $for K in range(1, 9):
        const ${CTYPE}* i${K} = ${K} < k ? *i++ : i0;
      $for K in range(9):
        i${K} = (const ${CTYPE}*) ((uintptr_t) i${K} + input_offset);

      o = output;
      size_t c = channels;
      do {
        size_t vl = __riscv_vsetvl_e32m${LMUL}(c);

        $for K in range(9):
          ${VTYPE} vi${K} = ${VLOAD}(i${K}, vl); i${K} += vl;

        ${VTYPE} vprev = ${VLOAD}(o, vl);

        ${VTYPE} vmax01 = __riscv_vfmax(vi0, vi1, vl);
        ${VTYPE} vmax23 = __riscv_vfmax(vi2, vi3, vl);
        ${VTYPE} vmax45 = __riscv_vfmax(vi4, vi5, vl);
        ${VTYPE} vmax67 = __riscv_vfmax(vi6, vi7, vl);
        ${VTYPE} vmax018 = __riscv_vfmax(vmax01, vi8, vl);

        ${VTYPE} vmax2345v = __riscv_vfmax(vmax23, vmax45, vl);
        ${VTYPE} vmax01678 = __riscv_vfmax(vmax67, vmax018, vl);
        ${VTYPE} vmax012345678 = __riscv_vfmax(vmax2345, vmax01678, vl);

        ${VTYPE} vacc = __riscv_vfmax(vprev, vmax012345678, vl);
        vacc = __riscv_vfmin(vacc, output_max, vl);
        ${VSTORE}(o, vacc, vl); o += vl;

        c -= vl;
      } while (c != 0);
    }
    input = (const ${CTYPE}**) ((uintptr_t) input + input_increment);
    input_offset += input_pixel_stride;
    output = (${CTYPE}*) ((uintptr_t) output + output_increment);
  } while (--output_pixels != 0);
}
